{
  "name": "fuel-app-frontend",
  "version": "1.0.0",
  "description": "React Native frontend for Fuel Pre-Order App",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace FuelApp.xcworkspace -scheme FuelApp -configuration Release -destination generic/platform=iOS -archivePath FuelApp.xcarchive archive",
    "clean": "react-native clean",
    "reset-cache": "react-native start --reset-cache"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.6",
